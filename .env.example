# .env.example - Configuration d'environnement

# ========================================
# 🚀 CONFIGURATION API BACKEND
# ========================================

# URL de base pour l'API backend
VITE_API_BASE_URL=http://localhost:8080/api/v1

# Utiliser l'API Mock (true) ou le backend réel (false)
VITE_USE_MOCK_API=true

# ========================================
# 📝 NOTES
# ========================================
# 
# DEVELOPMENT avec Mock API:
#   - Copiez ce fichier en .env
#   - VITE_USE_MOCK_API=true
#   - Modifiez USE_MOCK_API dans src/services/api.js si nécessaire
#
# DEVELOPMENT avec Backend Réel:
#   - Lancez Spring Boot sur http://localhost:8080
#   - VITE_USE_MOCK_API=false
#   - Assurez-vous que les endpoints /api/v1/* sont disponibles
#
# PRODUCTION:
#   - Définissez l'URL de production
#   - Désactivez USE_MOCK_API
#   - Vérifiez que CORS est configuré correctement
#
# ========================================
